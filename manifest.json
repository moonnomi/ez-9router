{
  "manifest_version": 3,
  "name": "ez-9router",
  "description": "Send selected text or images to a 9router model from the context menu.",
  "version": "0.1.0",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "action": {
    "default_title": "ez-9router",
    "default_popup": "src/popup.html"
  }
}
